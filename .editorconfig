# cambium — polyglot Rust (4-space) + Go (tabs) whitespace rules.
# Agrees with rustfmt and gofmt so the formatters and the editor never fight.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Rust — rustfmt default is 4-space soft tabs.
[*.rs]
indent_style = space
indent_size = 4

# Go — gofmt is canonical: hard tabs.
[*.go]
indent_style = tab
indent_size = 4

# Go module/workspace files are tab-indented.
[{go.mod,go.sum,go.work}]
indent_style = tab

[*.{toml,yml,yaml,json}]
indent_style = space
indent_size = 2

# Two trailing spaces are a hard line break in Markdown — don't strip them.
[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
